<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<AnchorPane

        prefWidth="900"
        prefHeight="650"

        styleClass="fondoLogin"
        stylesheets="@Styles.css"

        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"

        fx:controller="com.proyecto.sistema_citas_poli.Controller.CitaController">


    <VBox

            alignment="CENTER"
            spacing="20"

            AnchorPane.topAnchor="0"
            AnchorPane.bottomAnchor="0"
            AnchorPane.leftAnchor="0"
            AnchorPane.rightAnchor="0">


        <VBox

                alignment="CENTER"
                spacing="15"

                styleClass="tarjetaLogin">


            <padding>

                <Insets
                        top="35"
                        bottom="35"
                        left="45"
                        right="45"/>

            </padding>



            <Label

                    text="📅 Agendar cita"

                    styleClass="tituloLogin"/>



            <Label

                    text="Complete los datos de la cita"

                    styleClass="subtitulo"/>





            <ComboBox

                    fx:id="cbEspecialidad"

                    promptText="🩺 Especialidad"

                    prefWidth="280"

                    styleClass="campo"/>





            <ComboBox

                    fx:id="cbMedico"

                    promptText="👨‍⚕️ Médico"

                    prefWidth="280"

                    styleClass="campo"/>





            <DatePicker

                    fx:id="fecha"

                    promptText="📅 Fecha"

                    prefWidth="280"

                    styleClass="campo"/>






            <ComboBox

                    fx:id="cbHora"

                    promptText="⏰ Hora"

                    prefWidth="280"

                    styleClass="campo"/>






            <TextArea

                    fx:id="txtDescripcion"

                    promptText="Descripción del motivo de consulta"

                    prefWidth="280"

                    prefHeight="80"

                    styleClass="campo"/>






            <Button

                    text="✅ Guardar cita"

                    prefWidth="280"

                    prefHeight="45"

                    onAction="#guardarCita"

                    styleClass="botonPrincipal"/>





            <Button

                    text="⬅ Volver"

                    prefWidth="280"

                    prefHeight="40"

                    onAction="#volver"

                    styleClass="botonSecundario"/>




        </VBox>


    </VBox>


</AnchorPane>