<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane
        prefHeight="650"
        prefWidth="950"
        styleClass="fondoLogin"
        stylesheets="@Styles.css"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.proyecto.sistema_citas_poli.Controller.LoginController">

    <children>

        <HBox
                alignment="CENTER"
                spacing="60"
                AnchorPane.topAnchor="0"
                AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0">

            <!-- PANEL INFORMACIÓN -->

            <VBox
                    alignment="CENTER"
                    spacing="15"
                    prefWidth="400"
                    styleClass="panelInformacion">

                <Label
                        text="🌸"
                        styleClass="logoGrande"/>

                <Label
                        text="MediCitas POLI"
                        styleClass="tituloPrincipal"/>

                <Label
                        text="Sistema inteligente&#10;de gestión de citas médicas"
                        styleClass="descripcion"
                        wrapText="true"/>

                <Separator/>

                <Label
                        text="🩺 Agenda tus citas&#10;👨‍⚕️ Control médico&#10;📅 Seguimiento profesional"
                        styleClass="textoInfo"
                        wrapText="true"/>

            </VBox>

            <!-- TARJETA LOGIN -->

            <VBox
                    alignment="CENTER"
                    spacing="18"
                    prefWidth="360"
                    styleClass="tarjetaLogin">

                <padding>
                    <Insets
                            top="35"
                            bottom="35"
                            left="35"
                            right="35"/>
                </padding>

                <Label
                        text="Bienvenido"
                        styleClass="tituloLogin"/>

                <Label
                        text="Ingresa a tu cuenta"
                        styleClass="subtitulo"/>

                <TextField
                        fx:id="txtCorreo"
                        promptText="📧 Correo electrónico"
                        prefHeight="40"
                        styleClass="campo"/>

                <PasswordField
                        fx:id="txtContrasena"
                        promptText="🔒 Contraseña"
                        prefHeight="40"
                        styleClass="campo"/>

                <Button
                        fx:id="btnIngresar"
                        text="✨ Ingresar"
                        prefWidth="260"
                        prefHeight="45"
                        onAction="#ingresar"
                        styleClass="botonPrincipal"/>

                <Separator/>

                <Label
                        text="¿No tienes una cuenta?"
                        styleClass="textoSecundario"/>

                <Button
                        fx:id="btnRegistro"
                        text="🌸 Crear cuenta"
                        prefWidth="260"
                        prefHeight="40"
                        onAction="#abrirRegistro"
                        styleClass="botonSecundario"/>

            </VBox>

        </HBox>

    </children>

</AnchorPane>