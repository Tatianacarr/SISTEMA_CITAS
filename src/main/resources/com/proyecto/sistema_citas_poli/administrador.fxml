<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700" prefWidth="1200" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.sistema_citas_poli.Controller.AdministradorController">



    <!-- ================= CABECERA ================= -->


    <top>


        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="panelInformacion">


            <padding>
                <Insets bottom="15" left="20" right="20" top="15" />
            </padding>



            <Label styleClass="tituloPrincipal" text="🏥 MediCitas POLI" />



            <Pane HBox.hgrow="ALWAYS" />



            <Label fx:id="lblAdministrador" styleClass="textoInfo" text="Administrador" />


        </HBox>


    </top>





    <!-- ================= MENU LATERAL ================= -->


    <left>


        <VBox prefWidth="220" spacing="12" styleClass="panelInformacion">


            <padding>

                <Insets bottom="20" left="15" right="15" top="20" />

            </padding>




            <Button maxWidth="Infinity" onAction="#mostrarInicio" styleClass="botonPrincipal" text="🏠 Inicio" />




            <Button maxWidth="Infinity" onAction="#mostrarUsuarios" styleClass="botonPrincipal" text="👥 Pacientes" />




            <Button maxWidth="Infinity" onAction="#mostrarMedicos" styleClass="botonPrincipal" text="👨‍⚕️ Médicos" />




            <Button maxWidth="Infinity" onAction="#mostrarCitas" styleClass="botonPrincipal" text="📅 Citas" />



            <Region VBox.vgrow="ALWAYS" />




            <Button maxWidth="Infinity" onAction="#cerrarSesion" styleClass="botonSecundario" text="🚪 Cerrar sesión" />


        </VBox>


    </left>






    <!-- ================= CONTENIDO ================= -->


    <center>


        <StackPane fx:id="contenedorPrincipal">







            <!-- ================= PACIENTES ================= -->


            <VBox fx:id="panelUsuarios" spacing="15" visible="false">


                <Label styleClass="tituloLogin" text="👥 Gestión de Pacientes" />



                <HBox spacing="10">


                    <TextField fx:id="txtBuscarPaciente" promptText="🔍 Buscar paciente..." styleClass="campo" HBox.hgrow="ALWAYS" />



                    <Button onAction="#buscarPaciente" styleClass="botonPrincipal" text="Buscar" />


                </HBox>





                <TableView fx:id="tablaPacientes" VBox.vgrow="ALWAYS">


                    <columns>


                        <TableColumn fx:id="colPacienteId" prefWidth="60" text="ID" />


                        <TableColumn fx:id="colPacienteNombre" prefWidth="150" text="Nombre" />


                        <TableColumn fx:id="colPacienteApellido" prefWidth="150" text="Apellido" />


                        <TableColumn fx:id="colPacienteCorreo" prefWidth="250" text="Correo" />


                        <TableColumn fx:id="colPacienteTelefono" prefWidth="150" text="Teléfono" />


                    </columns>


                </TableView>




                <HBox alignment="CENTER" spacing="15">


                    <Button onAction="#nuevoPaciente" styleClass="botonPrincipal" text="➕ Nuevo" />



                    <Button onAction="#editarPaciente" styleClass="botonPrincipal" text="✏ Editar" />



                    <Button onAction="#eliminarPaciente" styleClass="botonSecundario" text="🗑 Eliminar" />



                    <Button onAction="#actualizarPacientes" styleClass="botonPrincipal" text="🔄 Actualizar" />


                </HBox>


            </VBox>




            <!-- ================= MEDICOS ================= -->


            <VBox fx:id="panelMedicos" spacing="15" visible="false">



                <Label styleClass="tituloLogin" text="👨‍⚕️ Gestión de Médicos" />




                <HBox spacing="10">



                    <TextField fx:id="txtBuscarMedico" promptText="🔍 Buscar médico o especialidad..." styleClass="campo" HBox.hgrow="ALWAYS" />



                    <Button onAction="#buscarMedico" styleClass="botonPrincipal" text="Buscar" />


                </HBox>






                <TableView fx:id="tablaMedicos" VBox.vgrow="ALWAYS">



                    <columns>



                        <TableColumn fx:id="colMedicoId" prefWidth="60" text="ID" />



                        <TableColumn fx:id="colMedicoNombre" prefWidth="140" text="Nombre" />



                        <TableColumn fx:id="colMedicoApellido" prefWidth="140" text="Apellido" />



                        <TableColumn fx:id="colMedicoEspecialidad" prefWidth="180" text="Especialidad" />



                        <TableColumn fx:id="colMedicoCorreo" prefWidth="230" text="Correo" />



                        <TableColumn fx:id="colMedicoTelefono" prefWidth="140" text="Teléfono" />



                    </columns>


                </TableView>






                <HBox alignment="CENTER" spacing="15">



                    <Button onAction="#nuevoMedico" styleClass="botonPrincipal" text="➕ Nuevo médico" />



                    <Button onAction="#editarMedico" styleClass="botonPrincipal" text="✏ Editar" />



                    <Button onAction="#eliminarMedico" styleClass="botonSecundario" text="🗑 Eliminar" />



                    <Button onAction="#actualizarMedicos" styleClass="botonPrincipal" text="🔄 Actualizar" />


                </HBox>



            </VBox>










            <!-- ================= CITAS ================= -->


            <VBox fx:id="panelCitas" spacing="15" visible="false">



                <Label styleClass="tituloLogin" text="📅 Citas Agendadas" />






                <TableView fx:id="tablaCitas" VBox.vgrow="ALWAYS">



                    <columns>



                        <TableColumn fx:id="colCitaId" prefWidth="60" text="ID" />



                        <TableColumn fx:id="colCitaPaciente" prefWidth="180" text="Paciente" />



                        <TableColumn fx:id="colCitaMedico" prefWidth="180" text="Médico" />



                        <TableColumn fx:id="colCitaEspecialidad" prefWidth="150" text="Especialidad" />



                        <TableColumn fx:id="colCitaFecha" prefWidth="120" text="Fecha" />



                        <TableColumn fx:id="colCitaHora" prefWidth="100" text="Hora" />



                        <TableColumn fx:id="colCitaEstado" prefWidth="120" text="Estado" />



                        <TableColumn fx:id="colCitaObservacion" prefWidth="200" text="Observación" />



                    </columns>


                </TableView>





            </VBox>





            <!-- ================= INICIO ================= -->

            <VBox fx:id="panelInicio"
                  alignment="CENTER"
                  spacing="25"
                  styleClass="panelInicioPastel">


                <Label text="🏥 Panel Administrativo"
                       styleClass="tituloAdminPastel"/>



                <Label text="🏥 Bienvenido al sistema MediCitas POLI"
                       styleClass="bienvenidaPastel"/>



                <VBox spacing="12"
                      styleClass="tarjetaInfoPastel">


                    <Label text="⚙ Funciones del administrador"
                           styleClass="subtituloPastel"/>



                    <Label text="✔ Gestionar pacientes registrados"
                           styleClass="textoPastel"/>



                    <Label text="✔ Administrar médicos"
                           styleClass="textoPastel"/>



                    <Label text="✔ Supervisar citas médicas"
                           styleClass="textoPastel"/>



                    <Label text="✔ Mantener actualizada la información del sistema"
                           styleClass="textoPastel"/>


                </VBox>





                <HBox spacing="25"
                      alignment="CENTER">



                    <VBox alignment="CENTER"
                          spacing="8"
                          styleClass="tarjetaNumeroPastel">


                        <Label text="👥"
                               styleClass="iconoPastel"/>


                        <Label fx:id="lblTotalPacientes"
                               text="Pacientes: 0"
                               styleClass="numeroPastel"/>


                    </VBox>





                    <VBox alignment="CENTER"
                          spacing="8"
                          styleClass="tarjetaNumeroPastel">


                        <Label text="👨‍⚕️"
                               styleClass="iconoPastel"/>


                        <Label fx:id="lblTotalMedicos"
                               text="Médicos: 0"
                               styleClass="numeroPastel"/>


                    </VBox>






                    <VBox alignment="CENTER"
                          spacing="8"
                          styleClass="tarjetaNumeroPastel">


                        <Label text="📅"
                               styleClass="iconoPastel"/>


                        <Label fx:id="lblTotalCitas"
                               text="Citas: 0"
                               styleClass="numeroPastel"/>


                    </VBox>




                </HBox>


            </VBox>




        </StackPane>



    </center>





</BorderPane>
