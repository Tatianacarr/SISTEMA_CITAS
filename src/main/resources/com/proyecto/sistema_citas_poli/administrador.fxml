<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.proyecto.sistema_citas_poli.Controller.AdministradorController"
        stylesheets="@Styles.css"
        prefWidth="1200"
        prefHeight="700">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="15"
              styleClass="panelInformacion">

            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label
                    text="🏥 MediCitas POLI"
                    styleClass="tituloPrincipal"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Label
                    fx:id="lblAdministrador"
                    text="Administrador"
                    styleClass="textoInfo"/>

        </HBox>
    </top>

    <!-- ================= MENÚ ================= -->

    <left>

        <VBox spacing="12"
              prefWidth="220"
              styleClass="panelInformacion">

            <padding>
                <Insets top="20" left="15" right="15" bottom="20"/>
            </padding>

            <Button
                    fx:id="btnInicio"
                    text="🏠 Inicio"
                    onAction="#mostrarInicio"
                    maxWidth="Infinity"
                    styleClass="botonPrincipal"/>

            <Button
                    fx:id="btnUsuarios"
                    text="👥 Usuarios"
                    onAction="#mostrarUsuarios"
                    maxWidth="Infinity"
                    styleClass="botonPrincipal"/>

            <Button
                    fx:id="btnMedicos"
                    text="👨‍⚕️ Médicos"
                    onAction="#mostrarMedicos"
                    maxWidth="Infinity"
                    styleClass="botonPrincipal"/>

            <Button
                    fx:id="btnPacientes"
                    text="🧑 Pacientes"
                    onAction="#mostrarPacientes"
                    maxWidth="Infinity"
                    styleClass="botonPrincipal"/>

            <Button
                    fx:id="btnCitas"
                    text="📅 Citas"
                    onAction="#mostrarCitas"
                    maxWidth="Infinity"
                    styleClass="botonPrincipal"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button
                    fx:id="btnCerrarSesion"
                    text="🚪 Cerrar sesión"
                    onAction="#cerrarSesion"
                    maxWidth="Infinity"
                    styleClass="botonSecundario"/>

        </VBox>

    </left>

    <!-- ================= CONTENIDO ================= -->

    <center>

        <VBox spacing="15">

            <padding>
                <Insets top="20" left="20" right="20" bottom="20"/>
            </padding>

            <Label
                    fx:id="lblTitulo"
                    text="Panel de Administración"
                    styleClass="tituloLogin"/>

            <HBox spacing="10">

                <TextField
                        fx:id="txtBuscar"
                        promptText="Buscar..."
                        HBox.hgrow="ALWAYS"
                        styleClass="campo"/>

                <Button
                        fx:id="btnBuscar"
                        text="🔍 Buscar"
                        onAction="#buscar"
                        styleClass="botonPrincipal"/>

            </HBox>

            <TableView fx:id="tablaDatos"
                       VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn
                            fx:id="col1"
                            text="ID"
                            prefWidth="80"/>

                    <TableColumn
                            fx:id="col2"
                            text="Nombre"
                            prefWidth="170"/>

                    <TableColumn
                            fx:id="col3"
                            text="Información"
                            prefWidth="250"/>

                    <TableColumn
                            fx:id="col4"
                            text="Estado"
                            prefWidth="150"/>

                </columns>

            </TableView>

            <HBox alignment="CENTER"
                  spacing="15">

                <Button
                        fx:id="btnNuevo"
                        text="➕ Nuevo"
                        onAction="#nuevo"
                        styleClass="botonPrincipal"/>

                <Button
                        fx:id="btnEditar"
                        text="✏ Editar"
                        onAction="#editar"
                        styleClass="botonPrincipal"/>

                <Button
                        fx:id="btnEliminar"
                        text="🗑 Eliminar"
                        onAction="#eliminar"
                        styleClass="botonSecundario"/>

                <Button
                        fx:id="btnActualizar"
                        text="🔄 Actualizar"
                        onAction="#actualizar"
                        styleClass="botonPrincipal"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>