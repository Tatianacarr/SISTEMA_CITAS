<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane
        prefWidth="900"
        prefHeight="650"
        styleClass="fondoLogin"
        stylesheets="@Styles.css"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.proyecto.sistema_citas_poli.Controller.PacienteController">


    <VBox

            alignment="CENTER"
            spacing="20"

            AnchorPane.topAnchor="0"
            AnchorPane.bottomAnchor="0"
            AnchorPane.leftAnchor="0"
            AnchorPane.rightAnchor="0">



        <VBox

                alignment="CENTER"
                spacing="20"
                styleClass="tarjetaLogin">


            <padding>

                <Insets
                        top="40"
                        bottom="40"
                        left="50"
                        right="50"/>

            </padding>


            <Label

                    fx:id="lblBienvenida"

                    text="Bienvenido paciente"

                    styleClass="tituloLogin"/>



            <Label

                    text="Panel del paciente"

                    styleClass="subtitulo"/>



            <Button

                    text="📅 Agendar cita"

                    prefWidth="260"
                    prefHeight="45"

                    onAction="#abrirCitas"

                    styleClass="botonPrincipal"/>




            <Button

                    text="📋 Mis citas"

                    prefWidth="260"

                    prefHeight="45"

                    onAction="#misCitas"

                    styleClass="botonPrincipal"/>





            <Button

                    text="🚪 Cerrar sesión"

                    prefWidth="260"

                    prefHeight="40"

                    onAction="#cerrarSesion"

                    styleClass="botonSecundario"/>



        </VBox>


    </VBox>


</AnchorPane>